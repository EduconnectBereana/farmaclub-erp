{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/apps/farmaclub_site.html" },
    { "source": "/site", "destination": "/apps/farmaclub_site.html" },
    { "source": "/comprar", "destination": "/apps/farmaclub_app_cliente.html" },
    { "source": "/cliente", "destination": "/apps/farmaclub_app_cliente.html" },
    { "source": "/motoboy", "destination": "/apps/farmaclub_app_motoboy.html" },
    { "source": "/erp", "destination": "/apps/farmaclub_erp_central.html" },
    { "source": "/central", "destination": "/apps/farmaclub_erp_central.html" },
    { "source": "/farmacia", "destination": "/apps/farmaclub_erp_farmacia.html" },
    { "source": "/contabilidade", "destination": "/apps/farmaclub_contabilidade.html" },
    { "source": "/pagamentos", "destination": "/apps/farmaclub_marketplace_pagamentos.html" },
    { "source": "/cadastro-fiscal", "destination": "/apps/farmaclub_cadastro_fiscal.html" },
    { "source": "/setup", "destination": "/apps/farmaclub_setup.html" },
    { "source": "/instalar", "destination": "/apps/farmaclub_instalar.html" },
    { "source": "/seguranca", "destination": "/apps/farmaclub_seguranca.html" },
    { "source": "/compras", "destination": "/apps/farmaclub_compra_coletiva.html" },
    { "source": "/piloto", "destination": "/apps/farmaclub_piloto.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/public/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600" }
      ]
    }
  ]
}
